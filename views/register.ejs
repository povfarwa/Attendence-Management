<!DOCTYPE html>
<html lang="en">
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <title>AttendX | Admin Join</title>
</head>
<body class="bg-[#0f172a] text-white flex items-center justify-center min-h-screen">
    <div class="bg-slate-800/50 p-10 rounded-3xl shadow-2xl border border-slate-700 w-full max-w-md backdrop-blur-md">
        <h1 class="text-3xl font-bold mb-2 text-center text-blue-400">AttendX.</h1>
        <p class="text-slate-400 text-center mb-8 text-sm uppercase tracking-widest">Admin Registration</p>
        
        <form action="/register" method="POST" class="space-y-5">
            <input type="text" name="name" placeholder="Full Name" class="w-full bg-slate-900 border border-slate-700 p-4 rounded-xl outline-none focus:border-blue-500 transition-all text-sm">
            <input type="email" name="email" placeholder="Admin Email" class="w-full bg-slate-900 border border-slate-700 p-4 rounded-xl outline-none focus:border-blue-500 transition-all text-sm">
            <input type="password" name="password" placeholder="Secure Password" class="w-full bg-slate-900 border border-slate-700 p-4 rounded-xl outline-none focus:border-blue-500 transition-all text-sm">
            <button class="w-full bg-blue-600 hover:bg-blue-500 font-bold py-4 rounded-xl shadow-lg shadow-blue-600/20 transition-all">Create Admin Account</button>
        </form>
        <p class="text-center mt-6 text-slate-500 text-sm">Already an admin? <a href="/login" class="text-blue-400">Sign In</a></p>
    </div>
</body>
</html>