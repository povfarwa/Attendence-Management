<!DOCTYPE html>
<html lang="en">
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <title>Student Report | AttendX</title>
</head>
<body class="bg-[#090e1a] text-slate-300 min-h-screen p-8">
    
    <div class="max-w-4xl mx-auto">
        <div class="flex justify-between items-center mb-10">
            <a href="/dashboard" class="text-sm text-blue-400 hover:underline">← Back to Dashboard</a>
            <h2 class="text-2xl font-bold text-white italic">AttendX.</h2>
        </div>

        <div class="bg-slate-800/40 p-8 rounded-[2.5rem] border border-slate-700 mb-8 flex flex-col md:flex-row justify-between items-center gap-6">
            <div>
                <h1 class="text-4xl font-black text-white"><%= student.name %></h1>
                <p class="text-slate-500 mt-1 uppercase tracking-widest text-xs font-bold">
                    Class: <%= student.studentClass %> | Roll No: <%= student.rollNumber %>
                </p>
            </div>
            <div class="text-center bg-blue-600/20 p-4 rounded-3xl border border-blue-500/30">
                <p class="text-blue-400 text-xs font-bold uppercase">Total Records</p>
                <h4 class="text-3xl font-bold text-blue-400"><%= student.attendanceRecords.length %></h4>
            </div>
        </div>

        <div class="bg-slate-900 rounded-[2.5rem] p-8 border border-slate-800 mb-8">
            <h3 class="text-white font-bold mb-6 italic">Attendance Trend</h3>
            <div class="h-[300px]">
                <canvas id="studentTrendChart"></canvas>
            </div>
        </div>

        <div class="bg-slate-800/20 rounded-[2.5rem] p-8 border border-slate-800">
            <h3 class="text-white font-bold mb-6">Recent History</h3>
            <div class="space-y-3">
                <% if(student.attendanceRecords.length > 0) { %>
                    <% student.attendanceRecords.reverse().forEach(record => { %>
                        <div class="flex items-center justify-between p-4 bg-slate-900/50 rounded-2xl border border-slate-700/50">
                            <span class="text-sm font-medium text-slate-400">
                                <%= new Date(record.date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                            </span>
                            <span class="px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-tighter 
                                <%= record.status === 'Present' ? 'bg-emerald-500/10 text-emerald-500 border border-emerald-500/20' : 
                                   record.status === 'Absent' ? 'bg-red-500/10 text-red-400 border border-red-400/20' : 
                                   'bg-amber-500/10 text-amber-500 border border-amber-500/20' %>">
                                <%= record.status %>
                            </span>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-center text-slate-600 py-10">No attendance records found for this student.</p>
                <% } %>
            </div>
        </div>
    </div>

    <script>
        const ctx = document.getElementById('studentTrendChart').getContext('2d');
        
        // Backend se data nikal kar Chart mein dalna
        // 1 for Present, 0 for Absent
        const rawData = <%- JSON.stringify(student.attendanceRecords) %>;
        const labels = rawData.map(r => new Date(r.date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }));
        const dataValues = rawData.map(r => r.status === 'Present' ? 1 : 0);

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Attendance (1=P, 0=A)',
                    data: dataValues,
                    borderColor: '#3b82f6',
                    backgroundColor: 'rgba(59, 130, 246, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 5,
                    pointBackgroundColor: '#3b82f6'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { 
                        min: -0.5, 
                        max: 1.5,
                        ticks: { stepSize: 1, color: '#64748b' },
                        grid: { color: '#1e293b' }
                    },
                    x: { ticks: { color: '#64748b' }, grid: { display: false } }
                },
                plugins: { legend: { display: false } }
            }
        });
    </script>
</body>
</html>