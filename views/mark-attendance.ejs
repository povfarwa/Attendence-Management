<!DOCTYPE html>
<html lang="en">
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Mark Attendance | AttendX</title>
</head>
<body class="bg-[#090e1a] text-slate-300 min-h-screen flex items-center justify-center p-6">
    <div class="max-w-2xl w-full bg-slate-800/40 p-8 rounded-[2.5rem] border border-slate-700 shadow-2xl">
        <div class="flex justify-between items-center mb-8">
            <h2 class="text-2xl font-bold text-white">Daily Attendance</h2>
            <span class="text-slate-500 text-sm font-mono"><%= new Date().toLocaleDateString() %></span>
        </div>

        <form action="/attendance/submit" method="POST">
            <div class="space-y-4 mb-8">
                <% students.forEach((student, index) => { %>
                    <div class="flex items-center justify-between bg-slate-900/50 p-4 rounded-2xl border border-slate-700">
                        <span class="text-white font-medium"><%= student.name %> <span class="text-slate-600 text-xs">(#<%= student.rollNumber %>)</span></span>
                        
                        <input type="hidden" name="attendanceData[<%= index %>][studentId]" value="<%= student._id %>">
                        <div class="flex gap-4">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="attendanceData[<%= index %>][status]" value="Present" checked class="accent-emerald-500">
                                <span class="text-xs font-bold text-emerald-500">P</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="attendanceData[<%= index %>][status]" value="Absent" class="accent-red-500">
                                <span class="text-xs font-bold text-red-500">A</span>
                            </label>
                        </div>
                    </div>
                <% }) %>
            </div>
            <button class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-4 rounded-2xl transition-all shadow-lg shadow-blue-600/20">Submit Final Attendance</button>
        </form>
    </div>
</body>
</html>