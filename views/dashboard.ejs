<!DOCTYPE html>
<html lang="en">
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <title>Dashboard | AttendX</title>
</head>
<body class="bg-[#090e1a] text-slate-300 min-h-screen">
    <nav class="border-b border-slate-800 p-6 flex justify-between items-center bg-[#090e1a]/80 sticky top-0 backdrop-blur-md">
        <h2 class="text-2xl font-black text-white italic">AttendX.</h2>
        <div class="flex items-center gap-4">
            <span class="text-xs bg-blue-500/10 text-blue-400 px-3 py-1 rounded-full border border-blue-400/20">Admin: <%= user.name %></span>
            <a href="/logout" class="text-sm text-red-400 font-bold">Logout</a>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto p-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <div class="bg-slate-800/40 p-6 rounded-3xl border border-slate-700">
                <p class="text-slate-500 text-xs font-bold uppercase">Total Students</p>
                <h3 class="text-4xl font-bold text-white mt-2"><%= totalStudents %></h3>
            </div>
            <div class="bg-blue-600 p-6 rounded-3xl shadow-xl shadow-blue-600/10">
                <p class="text-blue-100 text-xs font-bold uppercase">Actions</p>
                <a href="/attendance/mark" class="block mt-2 text-xl font-bold text-white hover:underline">Mark Today's Attendence→</a>
            </div>
        </div>

        <div class="bg-slate-800/40 p-8 rounded-3xl border border-slate-700 mb-10">
            <h3 class="text-lg font-bold text-white mb-6 italic">Attendance Overview</h3>
            <canvas id="attendanceChart" height="100"></canvas>
        </div>

        <div class="bg-slate-900 rounded-3xl p-6 border border-slate-800">
            <h3 class="text-white font-bold mb-4">Register Students</h3>
            
            <form action="/add-student" method="POST" class="flex flex-col md:flex-row gap-4 mb-8">
                <input type="text" name="name" placeholder="Student Name" required class="bg-slate-800 p-3 rounded-xl outline-none text-sm w-full border border-slate-700">
                
                <input type="text" name="studentClass" placeholder="Class (e.g. 10th)" required class="bg-slate-800 p-3 rounded-xl outline-none text-sm w-full border border-slate-700">
                
                <input type="text" name="rollNumber" placeholder="Roll No" required class="bg-slate-800 p-3 rounded-xl outline-none text-sm border border-slate-700">
                
                <button class="bg-emerald-500 text-black font-bold px-8 py-3 rounded-xl hover:bg-emerald-400 transition-all">Add Student</button>
            </form>

            <div class="space-y-3">
                <% students.forEach(student => { %>
                    <div class="flex items-center justify-between p-4 bg-slate-800/30 rounded-2xl border border-slate-700/50">
                        <div>
                            <p class="text-white font-bold"><%= student.name %></p>
                            <p class="text-xs text-slate-400">Class: <%= student.studentClass %> | Roll: <%= student.rollNumber %></p>
                        </div>
                        <a href="/student/<%= student._id %>/report" class="text-xs font-bold text-blue-400 bg-blue-400/10 px-4 py-2 rounded-lg hover:bg-blue-400 hover:text-white transition-all">View History</a>
                    </div>
                <% }) %>
            </div>
        </div>
    </main>

    <script>
        const ctx = document.getElementById('attendanceChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri'],
                datasets: [{
                    label: 'Students Present',
                    data: [12, 19, 15, 17, 14],
                    backgroundColor: '#3b82f6',
                    borderRadius: 10
                }]
            },
            options: { scales: { y: { beginAtZero: true, grid: { color: '#1e293b' } } } }
        });
    </script>
</body>
</html>